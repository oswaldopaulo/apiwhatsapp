APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=apiwhatsapp
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_TIMEOUT=120
QUEUE_WORKER_BACKOFF=30
QUEUE_WORKER_MEMORY=256
QUEUE_WORKER_SLEEP=3

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_CONNECTION=default
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=apiwhatsapp

WHATSAPP_QUEUE_DRIVER=default
WHATSAPP_QUEUE_CONNECTION=
WHATSAPP_QUEUE_NAME=messages
WHATSAPP_DEFAULT_DELAY_MIN=3
WHATSAPP_DEFAULT_DELAY_MAX=12
WHATSAPP_MAX_MESSAGES_PER_MINUTE=20
WHATSAPP_QUEUE_CONGESTION_THRESHOLD=100
WHATSAPP_ANTI_BAN_ENABLED=true
WHATSAPP_ANTI_BAN_REDIS_CONNECTION=default
WHATSAPP_ANTI_BAN_KEY_PREFIX=whatsapp:anti-ban
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
WHATSAPP_WEBHOOK_TIMESTAMP_HEADER=X-Webhook-Timestamp
WHATSAPP_WEBHOOK_TOLERANCE_SECONDS=300
WHATSAPP_OUTGOING_WEBHOOK_MAX_PAYLOAD_BYTES=16384
WHATSAPP_MONGODB_CONNECTION=mongodb
WHATSAPP_MESSAGES_COLLECTION=messages
WHATSAPP_MESSAGE_LOGS_COLLECTION=message_logs
WHATSAPP_WEBHOOK_EVENTS_COLLECTION=webhook_events
WHATSAPP_SESSION_EVENTS_COLLECTION=session_events
WHATSAPP_QUEUE_EVENTS_COLLECTION=queue_events
WHATSAPP_OUTGOING_WEBHOOK_LOGS_COLLECTION=outgoing_webhook_logs
WHATSAPP_STATISTICS_COLLECTION=statistics
WHATSAPP_PRESENCE_CHANNEL_PREFIX=tenant
WHATSAPP_STATS_CACHE_SECONDS=60

AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=180
AUDIT_LOG_MONGODB_COLLECTION=audit_logs
AUDIT_ACTIVITY_LOG_ENABLED=true
AUDIT_ACTIVITY_LOG_NAME=audit
AUDIT_METADATA_MAX_STRING_LENGTH=500

API_TENANT_HEADER=X-Tenant-ID
API_TENANT_REQUIRED=true
API_RATE_LIMIT_PER_MINUTE=120
API_AUTH_RATE_LIMIT_PER_MINUTE=20
API_WEBHOOK_RATE_LIMIT_PER_MINUTE=300
API_RATE_LIMIT_STORE=database

PASSPORT_AUTHORIZATION_GUARD=web
PASSPORT_ACCESS_TOKEN_MINUTES=15
PASSPORT_REFRESH_TOKEN_DAYS=30
PASSPORT_PERSONAL_ACCESS_TOKEN_DAYS=7
PASSPORT_PRIVATE_KEY=
PASSPORT_PUBLIC_KEY=
PASSPORT_CONNECTION=

QUEUE_DEFAULT_NAME=default
WEBHOOK_QUEUE_NAME=webhooks
EVENT_QUEUE_NAME=events
STATISTICS_QUEUE_NAME=statistics

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SCALING_ENABLED=false
REDIS_BROADCAST_CONNECTION=default
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
