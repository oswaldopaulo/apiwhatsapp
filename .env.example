APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=apiwhatsapp
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids
QUEUE_WORKER_TRIES=3
QUEUE_WORKER_TIMEOUT=120
QUEUE_WORKER_BACKOFF=30
QUEUE_WORKER_MEMORY=256
QUEUE_WORKER_SLEEP=3

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_CONNECTION=default
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_LOCK_CONNECTION=default

MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=apiwhatsapp

WHATSAPP_QUEUE_DRIVER=default
WHATSAPP_QUEUE_CONNECTION=
WHATSAPP_QUEUE_NAME=messages
WHATSAPP_DEFAULT_DELAY_MIN=3
WHATSAPP_DEFAULT_DELAY_MAX=12
WHATSAPP_MAX_MESSAGES_PER_MINUTE=20
WHATSAPP_ANTI_BAN_ENABLED=true
WHATSAPP_ANTI_BAN_REDIS_CONNECTION=default
WHATSAPP_ANTI_BAN_KEY_PREFIX=whatsapp:anti-ban
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_WEBHOOK_SIGNATURE_HEADER=X-Webhook-Signature
WHATSAPP_WEBHOOK_TIMESTAMP_HEADER=X-Webhook-Timestamp
WHATSAPP_WEBHOOK_TOLERANCE_SECONDS=300
WHATSAPP_MONGODB_CONNECTION=mongodb
WHATSAPP_MESSAGES_COLLECTION=messages
WHATSAPP_EVENTS_COLLECTION=event_logs
WHATSAPP_WEBHOOKS_COLLECTION=webhook_deliveries
WHATSAPP_STATISTICS_COLLECTION=statistics
WHATSAPP_PRESENCE_CHANNEL_PREFIX=tenant

API_TENANT_HEADER=X-Tenant-Id
API_TENANT_REQUIRED=true
API_RATE_LIMIT_PER_MINUTE=120
API_AUTH_RATE_LIMIT_PER_MINUTE=20
API_WEBHOOK_RATE_LIMIT_PER_MINUTE=300
API_RATE_LIMIT_STORE=database

QUEUE_DEFAULT_NAME=default
WEBHOOK_QUEUE_NAME=webhooks
EVENT_QUEUE_NAME=events
STATISTICS_QUEUE_NAME=statistics

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
